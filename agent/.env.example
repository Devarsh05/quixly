# Agent service — local env template.
# Copy to `.env` and fill in. NEVER commit real values.

# Runtime
ENVIRONMENT=development
LOG_LEVEL=info

# Infrastructure (matches docker-compose.yml for local dev).
# Alembic owns the `public` schema of this database; Prisma (app/) owns `shopify`.
DATABASE_URL=postgresql+asyncpg://quixly:quixly@localhost:5432/quixly
REDIS_URL=redis://localhost:6379/0

# Internal app-shell <-> agent API.
# INTERNAL_API_KEY is a shared secret and must match app/.env EXACTLY.
#
# The app shell is the SINGLE refresh authority for Shopify offline tokens: they expire
# after ~60 minutes, and minting a new one invalidates the previous token's refresh
# token. The agent therefore stores no Shopify credential — it calls back to the app
# shell at APP_SHELL_URL for a short-lived token whenever it needs one.
INTERNAL_API_KEY=
APP_SHELL_URL=http://localhost:3000

# Shopify Admin API version — must match `api_version` in app/shopify.app.toml.
SHOPIFY_API_VERSION=2026-07

# AI shopping-engine API keys (leave blank until Phase 2)
PERPLEXITY_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# EngineRunner / Perplexity Sonar knobs (defaults are sensible; override only if needed).
# PERPLEXITY_TEMPERATURE is pinned so share-of-model stays comparable across periods.
PERPLEXITY_MODEL=sonar
PERPLEXITY_TEMPERATURE=0.2
PERPLEXITY_TIMEOUT_SECONDS=30.0
ENGINE_MAX_CONCURRENCY=5
ENGINE_MAX_RETRIES=3

# Extractor (OpenAI Structured Outputs) knobs.
# gpt-5-nano is a reasoning model: no temperature is sent; EXTRACTOR_REASONING_EFFORT is pinned
# to "minimal" (strict-schema extraction needs no reasoning). Bump to "low" only if ranking is poor.
OPENAI_EXTRACTOR_MODEL=gpt-5-nano
OPENAI_TIMEOUT_SECONDS=30.0
EXTRACTOR_REASONING_EFFORT=minimal
EXTRACTOR_MAX_CONCURRENCY=5
EXTRACTOR_MAX_RETRIES=3
