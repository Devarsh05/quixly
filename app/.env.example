# App shell (Shopify React Router template) — local env template.
# Copy to `.env` and fill in. NEVER commit real values.
#
# For local development, `npm run dev` (shopify app dev) manages most of these
# for you via the Shopify CLI (API key/secret, app URL, tunneling). These are
# listed here for reference and for non-CLI / deployed environments.

# Shopify app credentials (from your Partners dashboard / `shopify app dev`)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Public URL of the app (set automatically by the CLI tunnel in local dev)
SHOPIFY_APP_URL=

# Comma-separated Admin API access scopes (kept in sync via shopify.app.toml)
SCOPES=

# Session storage. Prisma owns ONLY the Session table, and only inside the `shopify`
# Postgres schema — Alembic (agent/) owns every other table, in `public`.
# See CLAUDE.md > "Schema ownership". Note the plain `postgresql://` scheme: the agent
# addresses this same database as `postgresql+asyncpg://`. One DB, two drivers, two schemas.
DATABASE_URL=postgresql://quixly:quixly@localhost:5432/quixly?schema=shopify

# Internal app <-> agent API (see agent/.env.example).
# INTERNAL_API_KEY is a shared secret and must match agent/.env EXACTLY.
AGENT_SERVICE_URL=http://localhost:8000
INTERNAL_API_KEY=
